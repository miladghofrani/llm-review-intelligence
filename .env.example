# ── Required ───────────────────────────────────────────────────────────────────

# HuggingFace access token — needed to push the dataset and pull the adapter.
# Get yours at https://huggingface.co/settings/tokens (write access required)
HF_TOKEN=your_hf_token_here

# DeepL API key — used to translate German/French reviews to English before inference.
# Free tier (500k chars/month) is enough for most use cases.
# Get yours at https://www.deepl.com/your-account/keys
DEEPL_API_KEY=your_deepl_api_key_here

# Groq API key — used by scripts/generate_dataset.py to generate synthetic training data.
# Only needed if you want to generate or extend the dataset. Free tier available.
# Get yours at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Claude API key — used by scripts/label_reviews.py to generate high-quality sentiment
# and categories for real Floyt reviews. One-time labeling job, ~$5 per 5000 reviews.
# Get yours at https://console.anthropic.com/settings/keys
CLAUDE_API_KEY=your_claude_api_key_here

# ── Optional overrides ─────────────────────────────────────────────────────────

# Base model to fine-tune. Defaults to google/flan-t5-large.
# Other options: google/flan-t5-base (faster, lower quality)
# MODEL_NAME=google/flan-t5-large

# HuggingFace repo where the LoRA adapter is stored and loaded from.
# ADAPTER_PATH=miladghofrani/car-rental-peft-adapter-large

# Number of training epochs. Defaults to 1 (set to 3 for full training runs).
# NUM_EPOCHS=3

# Limit training to N steps — useful for quick smoke tests. 0 = full training.
# MAX_STEPS=0
